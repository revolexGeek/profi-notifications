[RabbitMQ]
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
RABBITMQ__VHOST=/

[PostgreSQL]
POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__USERNAME=postgres
POSTGRES__PASSWORD=postgres
POSTGRES__DB=order_core

[Очереди / топология]
# Входящие — потребляем (имена из контрактов parser-worker и llm).
MESSAGING__PARSE_QUEUE=parse.results
MESSAGING__ASSESS_RESULT_QUEUE=assess.results
# Исходящие — публикуем (имена из контрактов llm и notifications).
MESSAGING__ASSESS_REQUEST_QUEUE=assess.requests
MESSAGING__NOTIFY_EXCHANGE=notifications
MESSAGING__NOTIFY_ROUTING_KEY=notify
# Надёжность приёма — свои обменники/очереди.
MESSAGING__DLX=order.dlx
MESSAGING__DLQ=order.dlq
MESSAGING__RETRY_EXCHANGE=order.retry
MESSAGING__RETRY_QUEUE=order.retry
MESSAGING__PREFETCH=10
MESSAGING__RETRY_DELAY_MS=30000
MESSAGING__MAX_ATTEMPTS=5

[Политика уведомления]
# Порог «мозга» поверх фильтра llm. 0 = доверяем llm.
ASSESSMENT__NOTIFY_THRESHOLD=0

[Outbox-реле]
OUTBOX__POLL_INTERVAL_MS=1000
OUTBOX__BATCH_SIZE=100
OUTBOX__MAX_ATTEMPTS=10

[Логирование]
LOG_LEVEL=info
