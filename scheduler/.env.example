[RabbitMQ]
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
RABBITMQ__VHOST=/

[Планировщик]
# Интервал публикации команды парсинга, секунды.
SCHEDULER__PARSE_INTERVAL_SECONDS=300
# Целевая очередь (контракт parser-worker).
SCHEDULER__PARSE_QUEUE=parse.requests
# Параметры команды парсинга.
SCHEDULER__PARSE_MAX_PAGES=1
SCHEDULER__PARSE_SEARCH_QUERY=

[Логирование]
LOG_LEVEL=info
