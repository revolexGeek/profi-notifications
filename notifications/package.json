{
  "name": "@profi/notifications",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight service that consumes messages from RabbitMQ and delivers them to a Telegram channel.",
  "type": "module",
  "module": "src/main.ts",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch run src/main.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "publish:sample": "bun run scripts/publish-sample.ts"
  },
  "dependencies": {
    "rabbitmq-client": "^5.0.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
