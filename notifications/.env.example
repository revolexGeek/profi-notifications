# ── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather. The bot must be a member of the target chat with
# permission to post (an admin for channels).
TELEGRAM_BOT_TOKEN=<your-bot-token-from-BotFather>
# Target chat:
#   - channel:                @username  or  -100<internal_id>
#   - supergroup with topics: -100<internal_id>
# For a private supergroup link https://t.me/c/1234567890/2 the chat id is
# "-100" + the number after /c/  =>  -1001234567890, and 2 is the topic id.
TELEGRAM_CHAT_ID=-1001234567890
# Default forum topic (message_thread_id) for supergroups with topics. Optional:
# a message can override it via the "messageThreadId" payload field. From the
# link above this is 2. Leave empty for channels or the "General" topic.
TELEGRAM_MESSAGE_THREAD_ID=2
# Override for testing / self-hosted Bot API. No trailing slash.
TELEGRAM_API_BASE_URL=https://api.telegram.org
# Per-request timeout for the Telegram HTTP call, in milliseconds.
TELEGRAM_TIMEOUT_MS=10000

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Consumer QoS: unacked messages allowed in flight per consumer.
RABBITMQ_PREFETCH=10
# Handlers processed in parallel.
RABBITMQ_CONCURRENCY=5

# ── Topology (safe defaults; override only if you own the naming scheme) ──────
NOTIFY_EXCHANGE=notifications
NOTIFY_QUEUE=notifications
NOTIFY_ROUTING_KEY=notify
NOTIFY_RETRY_EXCHANGE=notifications.retry
NOTIFY_RETRY_QUEUE=notifications.retry
NOTIFY_DLX=notifications.dlx
NOTIFY_DLQ=notifications.dlq

# ── Delivery policy ──────────────────────────────────────────────────────────
# How many delivery attempts before a message is routed to the DLQ.
NOTIFY_MAX_ATTEMPTS=5
# Delay a message spends in the retry queue before being re-delivered, in ms.
NOTIFY_RETRY_DELAY_MS=30000

# ── HTTP (health / readiness / metrics) ──────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# ── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
