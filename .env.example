
# RabbitMQ credentials (used by the broker and the parser AMQP URL)
RABBITMQ_USER=profi
RABBITMQ_PASS=change-me

# Shared logging level
LOG_LEVEL=info

# parser-worker
PARSER_REQUEST_QUEUE=parse.requests
PARSER_RESULT_EXCHANGE=
PARSER_RESULT_ROUTING_KEY=parse.results
PARSER_PROFI_GRAPHQL_URL=https://profi.ru/graphql

# auth-worker (optional overrides; code defaults apply when unset)
#PROFI_CHECK_INTERVAL=60
#PROFI_REFRESH_BEFORE=180
#PROFI_AUTH_EXPIRED_INTERVAL=300
#PROFI_ERROR_INTERVAL=60
#PROFI_REQUEST_TIMEOUT=30
#PROFI_RENEW_URL=https://profi.ru/auth/token/renew
#PROFI_TOUCH_URL=https://profi.ru/auth/token/touch
#PROFI_USER_AGENT=

# llm (оценка заявок через Groq)
GROQ__API_KEY=your-groq-api-key
GROQ__MODEL=llama-3.3-70b-versatile
ASSESSMENT__SUITABILITY_THRESHOLD=60

# scheduler (триггер парсинга по расписанию)
SCHEDULER__PARSE_INTERVAL_SECONDS=300
SCHEDULER__PARSE_MAX_PAGES=1
