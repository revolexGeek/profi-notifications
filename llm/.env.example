# RabbitMQ (в общем стеке URL собирается из RABBITMQ_USER/RABBITMQ_PASS)
LLM_AMQP_URL=amqp://guest:guest@localhost:5672/
LLM_INPUT_QUEUE=parse.results
LLM_NOTIFY_EXCHANGE=notifications
LLM_NOTIFY_ROUTING_KEY=notify
LLM_PREFETCH=1

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0
LLM_TIMEOUT=30

# Политика решения
SUITABILITY_THRESHOLD=60

# HTTP (health/ready) и логирование
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
LOG_LEVEL=info
