# RabbitMQ (в общем стеке username/password берутся из RABBITMQ_USER/RABBITMQ_PASS)
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
RABBITMQ__VHOST=/

# Groq
GROQ__API_KEY=your-groq-api-key
GROQ__MODEL=llama-3.3-70b-versatile
GROQ__TEMPERATURE=0
GROQ__TIMEOUT=30

# Очереди / топология
MESSAGING__INPUT_QUEUE=parse.results
MESSAGING__NOTIFY_EXCHANGE=notifications
MESSAGING__NOTIFY_ROUTING_KEY=notify
MESSAGING__PREFETCH=1

# Политика решения
ASSESSMENT__SUITABILITY_THRESHOLD=60

# Логирование
LOG_LEVEL=info
