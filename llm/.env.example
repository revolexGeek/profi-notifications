[RabbitMQ]
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
RABBITMQ__VHOST=/

[LLM / DeepInfra (OpenAI-совместимый)]
LLM__API_KEY=your-deepinfra-api-token
LLM__MODEL=Qwen/Qwen3-32B
LLM__BASE_URL=https://api.deepinfra.com/v1/openai
LLM__TEMPERATURE=0
LLM__MAX_TOKENS=2048
LLM__TIMEOUT=60
LLM__MAX_RETRIES=3
LLM__SERVICE_TIER=flex
# Qwen3 и др.: выключить «мышление» (<think>), иначе ответ обрезается. Для классификации не нужно.
LLM__ENABLE_THINKING=false

[Очереди / топология]
MESSAGING__INPUT_QUEUE=assess.requests
MESSAGING__RESULT_QUEUE=assess.results
MESSAGING__PREFETCH=1

[Политика решения]
ASSESSMENT__SUITABILITY_THRESHOLD=60

[Логирование]
LOG_LEVEL=info
